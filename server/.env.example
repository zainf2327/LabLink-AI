PORT=5001
NODE_ENV=production
FRONTEND_URL=http://<your-ec2-ip-or-domain>

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/dbname

# JWT
JWT_ACCESS_SECRET=your_jwt_access_secret_key_at_least_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_at_least_32_chars
ENCRYPTION_KEY=your_encryption_key_at_least_32_chars

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google OAuth & Calendar API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://<your-ec2-ip-or-domain>/api/v1/auth/google/callback

# AWS
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-north-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_SES_FROM_EMAIL=your_email_address
